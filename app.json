{
  "expo": {
    "name": "Life-OS",
    "slug": "life-os",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/All_in_all_logo.png",

    "scheme": "lifeos",
    "userInterfaceStyle": "automatic",

    "ios": {
      "icon": "./assets/images/All_in_all_logo.png"
    },

    "android": {
      "package": "com.pragateesh7.lifeos",
      "predictiveBackGestureEnabled": false,

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/All_in_all_logo.png",
        "backgroundColor": "#FFFFFF"
      },

      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ]
    },

    "web": {
      "output": "static",
      "favicon": "./assets/images/All_in_all_logo.png"
    },

    "plugins": [
      "expo-router",

      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/All_in_all_logo.png",
          "imageWidth": 220
        }
      ],

      [
        "expo-notifications",
        {
          "icon": "./assets/images/All_in_all_logo.png",
          "color": "#F97316",
          "defaultChannel": "default"
        }
      ],

      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "ef490d3f-a4fd-44ca-9656-fb0fbba2553a"
      }
    },

    "owner": "pragateesh"
  }
}